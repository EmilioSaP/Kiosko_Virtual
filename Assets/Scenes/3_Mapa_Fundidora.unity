MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 727752701}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 91fe67e90911c1846b512d8a54ec9644, type: 3}
  m_Name: 
  m_EditorClassIdentifier: '::'
  texto: {fileID: 1754499264}
  listaTextos:
  - "El parque tiene 144 hect\xE1reas, equivalente a unos 200 campos de f\xFAtbol
    profesional."
  - "El Paseo Santa Luc\xEDa mide 2.5 km y es el r\xEDo artificial m\xE1s largo de
    Latinoam\xE9rica."
  - "Parque Fundidora es uno de los pocos museos de arqueolog\xEDa industrial al
    aire libre, donde puedes caminar entre antiguas estructuras de acero."
  - "Es la sede del Festival Pa'l Norte, que re\xFAne m\xE1s de 200,000 personas
    en un fin de semana."
  - "Antes del parque exist\xEDa el Parque Cuauht\xE9moc, donde jugaban los Sultanes
    de Monterrey."
  - "Dentro del parque est\xE1 el Auditorio Citibanamex, construido usando parte
    de las antiguas naves industriales."
  tiempoCambio: 5
