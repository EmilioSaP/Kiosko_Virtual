  m_TableData:
  - m_Id: 6927933440
    m_Localized: "El Horno 3 es un antiguo horno alto de la Fundidora de Monterrey
      que hoy funciona como museo y centro interactivo de ciencia y tecnolog\xEDa."
    m_Metadata:
      m_Items: []
  - m_Id: 189564706816
    m_Localized: "Las chimeneas del Parque Fundidora son antiguas estructuras industriales
      que serv\xEDan para ventilar los hornos de la acerera; hoy, son monumentos
      hist\xF3ricos y s\xEDmbolos del legado industrial de Monterrey"
    m_Metadata:
      m_Items: []
  - m_Id: 275862511616
    m_Localized: "La Cineteca Nuevo Le\xF3n \"Alejandra Rangel Hinojosa\" es el principal
      espacio cultural de Monterrey dedicado a la difusi\xF3n, preservaci\xF3n y
      exhibici\xF3n del s\xE9ptimo arte"
    m_Metadata:
      m_Items: []
  - m_Id: 379457626112
    m_Localized: "Es una monumental fuente ornamental ubicada en un ectremo de Paseo
      Santa Luc\xEDa que rinde tributo al pasado industrial de Monterrey al simular
      el vertido de acero l\xEDquido."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
